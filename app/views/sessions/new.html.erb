<div class="bg-white shadow-md rounded-lg p-8">
  <% if alert = flash[:alert] %>
    <p class="py-2 px-3 bg-red-50 mb-5 text-red-500 font-medium rounded-lg text-sm" id="alert"><%= alert %></p>
  <% end %>

  <% if notice = flash[:notice] %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-lg text-sm" id="notice"><%= notice %></p>
  <% end %>

  <h1 class="font-bold text-2xl text-gray-900 mb-6"><%= t("sessions.new.title") %></h1>

  <%= form_with url: session_path, class: "contents" do |form| %>
    <div class="mb-4">
      <%= form.label :email, t("sessions.new.email"), class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.email_field :email, required: true, autofocus: true, autocomplete: "username",
          placeholder: t("sessions.new.email_placeholder"), value: params[:email],
          class: "block w-full shadow-sm rounded-md border border-gray-300 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 px-3 py-2" %>
    </div>

    <div class="mb-6">
      <%= form.label :password, t("sessions.new.password"), class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.password_field :password, required: true, autocomplete: "current-password",
          placeholder: t("sessions.new.password_placeholder"), maxlength: 72,
          class: "block w-full shadow-sm rounded-md border border-gray-300 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 px-3 py-2" %>
    </div>

    <div>
      <%= form.submit t("sessions.new.submit"),
          class: "w-full rounded-md px-4 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium cursor-pointer transition-colors" %>
    </div>
  <% end %>
</div>

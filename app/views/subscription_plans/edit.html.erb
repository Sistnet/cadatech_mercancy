<div class="mb-8">
  <h1 class="font-bold text-3xl text-gray-900"><%= t("subscription_plans.edit.title") %></h1>
  <p class="mt-2 text-sm text-gray-600"><%= t("subscription_plans.edit.subtitle", name: @plan.name) %></p>
</div>

<% subscriptions_count = @plan.subscriptions.count %>
<% if subscriptions_count > 0 %>
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-8">
    <h2 class="text-lg font-semibold text-gray-900 mb-4"><%= t("subscription_plans.edit.subscriptions_section") %></h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div>
        <span class="block text-sm font-medium text-gray-500"><%= t("subscription_plans.edit.total_subscriptions") %></span>
        <span class="text-sm text-gray-900"><%= subscriptions_count %></span>
      </div>
      <div>
        <span class="block text-sm font-medium text-gray-500"><%= t("subscription_plans.edit.active_subscriptions") %></span>
        <span class="text-sm text-gray-900"><%= @plan.subscriptions.current.count %></span>
      </div>
      <div>
        <span class="block text-sm font-medium text-gray-500"><%= t("subscription_plans.edit.inactive_subscriptions") %></span>
        <span class="text-sm text-gray-900"><%= @plan.subscriptions.inactive.count %></span>
      </div>
    </div>
  </div>
<% end %>

<%= render "form" %>

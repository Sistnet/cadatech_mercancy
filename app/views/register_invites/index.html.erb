<%# Header %>
<div class="flex flex-col sm:flex-row items-start sm:items-center justify-between mb-8 gap-4">
  <h1 class="font-bold text-3xl text-gray-900"><%= t("register_invites.title") %></h1>
  <div class="flex items-center gap-4">
    <%= link_to t("register_invites.actions.new"), new_register_invite_path,
        class: "bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition-colors text-sm font-medium" %>
  </div>
</div>

<%# Filters %>
<div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 mb-6">
  <%= form_with url: register_invites_path, method: :get, class: "flex flex-col sm:flex-row gap-4", data: { turbo_frame: "invites-results", controller: "debounce-submit" } do %>
    <div class="flex-1">
      <%= text_field_tag :search, @search,
          placeholder: t("register_invites.filters.search_placeholder"),
          data: { action: "input->debounce-submit#search" },
          class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-blue-500 focus:border-blue-500" %>
    </div>
    <div>
      <%= select_tag :status,
          options_for_select(
            [[t("register_invites.filters.all_statuses"), ""]] +
            %w[pending used expired].map { |s| [t("register_invites.statuses.#{s}"), s] },
            @status_filter
          ),
          class: "border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-blue-500 focus:border-blue-500" %>
    </div>
    <button type="submit" class="bg-gray-100 text-gray-700 px-4 py-2 rounded-lg hover:bg-gray-200 transition-colors text-sm font-medium cursor-pointer">
      <%= t("register_invites.filters.search") %>
    </button>
  <% end %>
</div>

<%# Table %>
<%= turbo_frame_tag "invites-results" do %>
<div class="bg-white shadow-sm rounded-lg overflow-hidden border border-gray-200">
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("register_invites.table.email") %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("register_invites.table.status") %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("register_invites.table.created_by") %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("register_invites.table.created_at") %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("register_invites.table.expires_at") %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("register_invites.table.url") %></th>
          <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider"></th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @invites.each do |invite| %>
          <%= render "register_invites/invite_row", invite: invite %>
        <% end %>
        <% if @invites.empty? %>
          <tr>
            <td colspan="7" class="px-6 py-8 text-center text-sm text-gray-500"><%= t("register_invites.table.empty") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<%# Pagination %>
<% if @total_pages > 1 %>
  <div class="flex items-center justify-between mt-6">
    <p class="text-sm text-gray-700">
      <%= pagination_info(@offset, PER_PAGE, @total) %>
    </p>
    <div class="flex gap-2">
      <% if @page > 1 %>
        <%= link_to t("register_invites.pagination.previous"),
            register_invites_path(page: @page - 1, status: @status_filter, search: @search),
            class: "px-3 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50" %>
      <% end %>
      <% if @page < @total_pages %>
        <%= link_to t("register_invites.pagination.next"),
            register_invites_path(page: @page + 1, status: @status_filter, search: @search),
            class: "px-3 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50" %>
      <% end %>
    </div>
  </div>
<% end %>
<% end %>

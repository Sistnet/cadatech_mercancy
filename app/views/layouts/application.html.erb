<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || t("app_name") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="<%= t("app_name") %>">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50 min-h-screen">
    <div data-controller="sidebar">
      <%# Top bar %>
      <nav class="fixed top-0 left-0 right-0 z-50 bg-white border-b border-gray-200 h-16 flex items-center justify-between px-4">
        <div class="flex items-center gap-3">
          <button data-action="sidebar#toggle" class="p-2 rounded-lg text-gray-500 hover:bg-gray-100 hover:text-gray-700 cursor-pointer">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>
          <span class="font-semibold text-gray-900 text-lg"><%= t("app_name") %></span>
        </div>
        <% if authenticated? %>
          <div class="flex items-center gap-4">
            <span class="text-sm text-gray-600"><%= current_admin.name %></span>
            <%= button_to t("nav.logout"), session_path, method: :delete,
                class: "text-sm text-gray-500 hover:text-gray-700 cursor-pointer" %>
          </div>
        <% end %>
      </nav>

      <%# Backdrop (mobile) %>
      <div data-sidebar-target="backdrop"
           data-action="click->sidebar#close"
           class="fixed inset-0 z-30 bg-black/50 hidden lg:hidden"></div>

      <%# Sidebar %>
      <aside data-sidebar-target="sidebar"
             class="fixed top-16 left-0 bottom-0 z-40 bg-white border-r border-gray-200 w-64 -translate-x-full lg:translate-x-0 sidebar-transition overflow-y-auto overflow-x-hidden">
        <nav class="p-3 space-y-1">
          <%= link_to root_path, class: "flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium #{controller_name == 'dashboard' ? 'bg-blue-50 text-blue-700' : 'text-gray-600 hover:bg-gray-100 hover:text-gray-900'}" do %>
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1h-2z"/>
            </svg>
            <span data-sidebar-label><%= t("nav.menu.dashboard") %></span>
          <% end %>

          <%= link_to stores_path, class: "flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium #{controller_name == 'stores' ? 'bg-blue-50 text-blue-700' : 'text-gray-600 hover:bg-gray-100 hover:text-gray-900'}" do %>
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
            </svg>
            <span data-sidebar-label><%= t("nav.menu.stores") %></span>
          <% end %>

          <%= link_to subscription_plans_path, class: "flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium #{controller_name == 'subscription_plans' ? 'bg-blue-50 text-blue-700' : 'text-gray-600 hover:bg-gray-100 hover:text-gray-900'}" do %>
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
            </svg>
            <span data-sidebar-label><%= t("nav.menu.subscription_plans") %></span>
          <% end %>
        </nav>
      </aside>

      <%# Main content %>
      <main class="pt-16 main-transition" style="margin-left: var(--sidebar-width, 16rem);">
        <div class="p-6">
          <%= yield %>
        </div>
      </main>
    </div>
  </body>
</html>

<%= turbo_frame_tag "dashboard" do %>
<div class="flex flex-col sm:flex-row items-start sm:items-center justify-between mb-8 gap-4">
  <h1 class="font-bold text-3xl text-gray-900"><%= t("dashboard.title") %></h1>
  <div class="flex items-center gap-1 bg-white rounded-lg border border-gray-200 p-1">
    <%= link_to t("dashboard.periods.today"), root_path(period: "today"),
        class: "px-3 py-1.5 text-sm font-medium rounded-md transition-colors #{@period == 'today' ? 'bg-blue-600 text-white' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50'}" %>
    <%= link_to t("dashboard.periods.week"), root_path(period: "week"),
        class: "px-3 py-1.5 text-sm font-medium rounded-md transition-colors #{@period == 'week' ? 'bg-blue-600 text-white' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50'}" %>
    <%= link_to t("dashboard.periods.month"), root_path(period: "month"),
        class: "px-3 py-1.5 text-sm font-medium rounded-md transition-colors #{@period == 'month' ? 'bg-blue-600 text-white' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50'}" %>
  </div>
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-6">
  <%# Pedidos %>
  <div class="bg-blue-200 rounded-lg shadow-sm border border-blue-300 p-6">
    <div class="flex items-center gap-4">
      <div class="w-12 h-12 rounded-lg flex items-center justify-center">
        <svg class="w-6 h-6 text-blue-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
        </svg>
      </div>
      <div>
        <span class="text-sm font-medium text-blue-900"><%= t("dashboard.kpis.orders") %></span>
        <p class="text-2xl font-bold text-blue-950"><%= @kpis[:orders][:value] %></p>
      </div>
    </div>
    <% variation = format_variation(@kpis[:orders][:value], @kpis[:orders][:previous]) %>
    <p class="text-xs mt-3 font-medium text-blue-800">
      <%= variation_icon(variation) %> <%= t("dashboard.comparison", variation: variation) %>
    </p>
  </div>

  <%# Receita %>
  <div class="bg-green-200 rounded-lg shadow-sm border border-green-300 p-6">
    <div class="flex items-center gap-4">
      <div class="w-12 h-12 rounded-lg flex items-center justify-center">
        <svg class="w-6 h-6 text-green-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <div>
        <span class="text-sm font-medium text-green-900"><%= t("dashboard.kpis.revenue") %></span>
        <p class="text-2xl font-bold text-green-950"><%= format_currency(@kpis[:revenue][:value]) %></p>
      </div>
    </div>
    <% variation = format_variation(@kpis[:revenue][:value], @kpis[:revenue][:previous]) %>
    <p class="text-xs mt-3 font-medium text-green-800">
      <%= variation_icon(variation) %> <%= t("dashboard.comparison", variation: variation) %>
    </p>
  </div>

  <%# Novos Clientes %>
  <div class="bg-purple-200 rounded-lg shadow-sm border border-purple-300 p-6">
    <div class="flex items-center gap-4">
      <div class="w-12 h-12 rounded-lg flex items-center justify-center">
        <svg class="w-6 h-6 text-purple-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
      </div>
      <div>
        <span class="text-sm font-medium text-purple-900"><%= t("dashboard.kpis.customers") %></span>
        <p class="text-2xl font-bold text-purple-950"><%= @kpis[:customers][:value] %></p>
      </div>
    </div>
    <% variation = format_variation(@kpis[:customers][:value], @kpis[:customers][:previous]) %>
    <p class="text-xs mt-3 font-medium text-purple-800">
      <%= variation_icon(variation) %> <%= t("dashboard.comparison", variation: variation) %>
    </p>
  </div>

  <%# Produtos Ativos %>
  <div class="bg-amber-200 rounded-lg shadow-sm border border-amber-300 p-6">
    <div class="flex items-center gap-4">
      <div class="w-12 h-12 rounded-lg flex items-center justify-center">
        <svg class="w-6 h-6 text-amber-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
        </svg>
      </div>
      <div>
        <span class="text-sm font-medium text-amber-900"><%= t("dashboard.kpis.products") %></span>
        <p class="text-2xl font-bold text-amber-950"><%= @kpis[:products][:value] %></p>
      </div>
    </div>
    <% variation = format_variation(@kpis[:products][:value], @kpis[:products][:previous]) %>
    <p class="text-xs mt-3 font-medium text-amber-800">
      <%= variation_icon(variation) %> <%= t("dashboard.comparison", variation: variation) %>
    </p>
  </div>

  <%# Ticket Médio %>
  <div class="bg-indigo-200 rounded-lg shadow-sm border border-indigo-300 p-6">
    <div class="flex items-center gap-4">
      <div class="w-12 h-12 rounded-lg flex items-center justify-center">
        <svg class="w-6 h-6 text-indigo-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
        </svg>
      </div>
      <div>
        <span class="text-sm font-medium text-indigo-900"><%= t("dashboard.kpis.ticket") %></span>
        <p class="text-2xl font-bold text-indigo-950"><%= format_currency(@kpis[:ticket][:value]) %></p>
      </div>
    </div>
    <% variation = format_variation(@kpis[:ticket][:value], @kpis[:ticket][:previous]) %>
    <p class="text-xs mt-3 font-medium text-indigo-800">
      <%= variation_icon(variation) %> <%= t("dashboard.comparison", variation: variation) %>
    </p>
  </div>
</div>

<%# Gráficos %>
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mt-8">
  <%# Vendas por período %>
  <div class="lg:col-span-2 bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-4"><%= t("dashboard.charts.sales_title") %></h2>
    <div class="h-64">
      <canvas data-controller="chart"
              data-chart-type-value="line"
              data-chart-data-value="<%= @sales_chart.to_json %>"></canvas>
    </div>
  </div>

  <%# Pedidos por status %>
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-4"><%= t("dashboard.charts.status_title") %></h2>
    <div class="h-64">
      <canvas data-controller="chart"
              data-chart-type-value="doughnut"
              data-chart-data-value="<%= @status_chart.to_json %>"></canvas>
    </div>
  </div>
</div>

<%# Atividade recente %>
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mt-8">
  <%# Últimos pedidos %>
  <div class="lg:col-span-2 bg-white rounded-lg shadow-sm border border-gray-200">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900"><%= t("dashboard.recent_orders.title") %></h2>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("dashboard.recent_orders.order") %></th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("dashboard.recent_orders.customer") %></th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("dashboard.recent_orders.value") %></th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("dashboard.recent_orders.status") %></th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("dashboard.recent_orders.date") %></th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @recent_orders.each do |order| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-blue-600">#<%= order[:id] %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= order[:customer] %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= format_currency(order[:total]) %></td>
              <td class="px-6 py-4 whitespace-nowrap"><%= status_badge(order[:status]) %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= relative_time(order[:date]) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <%# Log de atividade %>
  <div class="bg-white rounded-lg shadow-sm border border-gray-200">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900"><%= t("dashboard.activity.title") %></h2>
    </div>
    <div class="divide-y divide-gray-200">
      <% @recent_activity.each do |activity| %>
        <div class="px-6 py-4">
          <p class="text-sm text-gray-900">
            <span class="font-medium"><%= activity[:admin] %></span>
            <%= activity[:action] %>
          </p>
          <p class="text-xs text-gray-500 mt-1"><%= relative_time(activity[:time]) %></p>
        </div>
      <% end %>
    </div>
  </div>
</div>
<% end %>

<%= form_with model: @store, class: "space-y-8" do |f| %>
  <%= render "shared/error_messages", record: @store, i18n_scope: "stores" %>

  <%# Basic Information %>
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-4"><%= t("stores.form.sections.basic") %></h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <%= f.label :name, t("stores.form.name"), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :name, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-blue-500 focus:border-blue-500", required: true %>
      </div>
      <div>
        <%= f.label :slug, t("stores.form.slug"), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :slug, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-blue-500 focus:border-blue-500", required: true %>
        <p class="mt-1 text-xs text-gray-500"><%= t("stores.form.slug_hint") %></p>
      </div>
      <div>
        <%= f.label :status, t("stores.form.status"), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.select :status, Store.statuses.keys.map { |s| [t("stores.statuses.#{s}"), s] },
            {}, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-blue-500 focus:border-blue-500" %>
      </div>
      <div>
        <%= f.label :person_type, t("stores.form.person_type"), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.select :person_type,
            [[t("stores.person_types.pf"), "pf"], [t("stores.person_types.pj"), "pj"]],
            { include_blank: true },
            class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-blue-500 focus:border-blue-500" %>
      </div>
    </div>
  </div>

  <%# Contact %>
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-4"><%= t("stores.form.sections.contact") %></h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <%= f.label :email, t("stores.form.email"), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.email_field :email, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-blue-500 focus:border-blue-500" %>
      </div>
      <div>
        <%= f.label :phone, t("stores.form.phone"), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :phone, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-blue-500 focus:border-blue-500" %>
      </div>
      <div>
        <%= f.label :whatsapp, t("stores.form.whatsapp"), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :whatsapp, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-blue-500 focus:border-blue-500" %>
      </div>
    </div>
  </div>

  <%# Documents %>
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-4"><%= t("stores.form.sections.documents") %></h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <%= f.label :cpf, t("stores.form.cpf"), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :cpf, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-blue-500 focus:border-blue-500" %>
      </div>
      <div>
        <%= f.label :cnpj, t("stores.form.cnpj"), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :cnpj, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-blue-500 focus:border-blue-500" %>
      </div>
      <div>
        <%= f.label :razao_social, t("stores.form.razao_social"), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :razao_social, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-blue-500 focus:border-blue-500" %>
      </div>
      <div>
        <%= f.label :nome_fantasia, t("stores.form.nome_fantasia"), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :nome_fantasia, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-blue-500 focus:border-blue-500" %>
      </div>
    </div>
  </div>

  <%# Commission %>
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-4"><%= t("stores.form.sections.commission") %></h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <%= f.label :commission_rate, t("stores.form.commission_rate"), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.number_field :commission_rate, step: 0.01, min: 0, max: 100,
            class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-blue-500 focus:border-blue-500" %>
        <p class="mt-1 text-xs text-gray-500"><%= t("stores.form.commission_rate_hint") %></p>
      </div>
    </div>
  </div>

  <div class="flex items-center gap-4">
    <%= f.submit class: "bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 transition-colors text-sm font-medium cursor-pointer" %>
    <%= link_to t("stores.actions.cancel"), stores_path, class: "text-sm text-gray-600 hover:text-gray-900" %>
  </div>
<% end %>
